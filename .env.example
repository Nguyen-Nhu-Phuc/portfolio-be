PORT=5000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vcard?retryWrites=true&w=majority
CORS_ORIGIN=http://localhost:3000
# Production (Vercel backend project)
# MONGODB_URI=mongodb+srv://...
# ADMIN_JWT_SECRET=change-this-to-a-long-random-secret
# CORS_ORIGIN=https://portfolio-fe-nine.vercel.app,http://localhost:3000
ADMIN_JWT_SECRET=change-this-to-a-long-random-secret

# Optional — email notifications for contact form
CONTACT_NOTIFY_EMAIL=you@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Portfolio <you@example.com>"

# Optional — only used by seed:admin when creating the first admin
ADMIN_DEFAULT_PASSWORD=admin123

# Image uploads (recommended for production / Vercel)
# When set, uploads go to Cloudinary instead of local disk.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_FOLDER=portfolio
